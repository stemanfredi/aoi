# Copy this file to `.env` and fill in your key. The `.env` is gitignored.

# OpenTopography API key — used by fetch.fetch_terrain to pull SRTM 30 m
# land DEM tiles for the land-side topographic contours.
#
# Get a free key:    https://opentopography.org/developers
# Free-tier quota:   50 API calls per 24 hours (cached per AOI after first hit).
#
# Without this key the engine still renders; the land terrain layer is
# simply omitted (land reads as flat buff). The OSM-derived land/sea
# boundary itself is unaffected.
OPENTOPOGRAPHY_API_KEY=
